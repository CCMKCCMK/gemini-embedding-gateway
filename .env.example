# ============================================================
# .env.example - 环境变量模板
# 使用前请复制为 .env 并填写真实值
# ============================================================

# ──────────────────────────────────────────────
# 必填项
# ──────────────────────────────────────────────

# Google AI Studio API Key（在 https://aistudio.google.com/app/apikey 获取）
GOOGLE_API_KEY=AIzaSy_你的密钥粘贴在这里

# 网关鉴权 Token（自定义一个密码，供你的应用调用网关时使用）
GATEWAY_TOKEN=sk-my-secret-token-2025

# 三个海外代理节点地址（部署后从 Render/Railway 控制台复制）
PROXY_1=https://你的节点1.onrender.com
PROXY_2=https://你的节点2.onrender.com
PROXY_3=https://你的节点3.onrender.com

# ──────────────────────────────────────────────
# 可选项（保持默认即可）
# ──────────────────────────────────────────────

# Embedding 模型名称
MODEL=gemini-embedding-2-preview

# 每分钟最大请求数（免费 Key 建议 60，付费 Key 可调高）
MAX_RPM=60

# 每批最大文本数（Gemini API 上限为 100）
BATCH_SIZE=100

# 最大并发请求数
MAX_CONCURRENT=10
